#==================================================================================================================================
# This example demonstrates natural language control of a Mingle application via Telegram and an LLM.
#
# Flow:
#   1. User sends a free-text message to the Telegram bot (e.g. "Switch the kitchen light off").
#   2. Rule 'forward' triggers script 'forward_to_agent', which writes the message to the AgentNL
#      device. The AgentNL controller automatically builds a context snapshot (devices, rules,
#      scripts) and forwards the enriched request to the MCP device for LLM processing.
#   3. When the LLM reply arrives, the AgentNL controller validates each action in the returned
#      JSON array, posts the corresponding messages to the EventBus, and echoes the raw LLM
#      response back to the user via Telegram (through the 'log' device).
#
# Prerequisites:
#   - A Telegram bot token and the chat id where messages will be sent/received.
#   - An MCP-compatible LLM endpoint and API key.
#
# LLM action schema (returned as a JSON array):
#   {"action":"write"  , "device":"<name>", "value":<value>}
#   {"action":"execute", "name":"<rule_or_script_name>"}
#   {"action":"unknown", "reason":"<explanation>"}
#
# ---------------------------------------------------------------------------------------------------------------------------------
# This file is part of the Mingle project, which is licensed under Apache 2.0 License
#
# @author : Francisco José Morero Peyrona
# @project: https://github.com/peyrona/mingle
#==================================================================================================================================

USE LLM_URI     AS "https://open.bigmodel.cn/api/paas/v4/chat/completions"  #"https://api.openai.com/v1/chat/completions"      # Replace with the actual URI
    LLM_API_KEY AS "e7b1b7f050a74454a6d81a763bfd2704.A4oFBJU45QvaBon9" # "YOUR_API_KEY_HERE"                               # Replace with your actual API key
    LLM_MODEL   AS "glm-4"  #"gpt-4o-mini"                                     # Or "gpt-4", "gpt-3.5-turbo", etc.
    IM_CHAT     AS "-336373800"                                      # Replace with your Telegram chat id
    IM_TOKEN    AS "531072848:AAGJ2X7lIWwpD5HNvpEXeKSkmOH2TThOIFc"   # Replace with your bot token


DEVICE telegram
    DRIVER TelegramDriver
    CONFIG
        chat  SET IM_CHAT
        token SET IM_TOKEN


DEVICE context
    DRIVER FileDriver
        CONFIG
            file     SET "{*home.etc*}agent_nl_context.txt"
            charset  SET "UTF-8"
            interval SET 0         # Time between reads. Default 0: only readed once, when ExEn starts.


DEVICE chatbot
    DRIVER MCPDriver
    CONFIG
        uri        SET LLM_URI
        api_key    SET LLM_API_KEY
        model      SET LLM_MODEL
        max_tokens SET 2048
        context    SET "context"    # The context to be added to every prompt


DEVICE console
    DRIVER OutputDriver


DEVICE agent
    DRIVER AgentNLDriver
    CONFIG
        mcp SET "chatbot"    # Delegate LLM calls to the 'chatbot' MCP device
        log SET "console"   # Echo the raw LLM response back to the Telegram user


WHEN telegram
THEN agent SET telegram

#------------------------------------------------------------------------------------------------------------------------------

DEVICE alarm
    DRIVER CellSetDriver
        CONFIG
            value SET OFF

DEVICE light_kitchen
    DRIVER CellSetDriver
        CONFIG
            value SET OFF


DEVICE light_bedroom
    DRIVER CellSetDriver
        CONFIG
            value SET OFF

# >>>>>>>>>>>>>> EOF <<<<<<<<<<<<<<<<