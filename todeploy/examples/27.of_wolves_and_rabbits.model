{"cmd":"rule","name":null,"when":"rabbits > 0 && get( \"day\" ):mod( 5) == 0","then":[{"after":-1,"target":"console","value":"\"[ Day \" + get( \"day\" ) + \" ]  Rabbits: \" + rabbits + \"  ·  Wolves: \" + wolves"}],"if":null},
{"cmd":"rule","name":null,"when":"rabbits == 0 && wolves > 0 && get( \"day\" ):mod( 5) == 0","then":[{"after":-1,"target":"console","value":"\"[ Day \" + get( \"day\" ) + \" ]  The meadow echoes.  \" + wolves + \" wolves remain, hunting silence.\""}],"if":null},
{"cmd":"rule","name":null,"when":"rabbits > 80 && get( \"gate\" ):get( \"r_boom\" , 0) == 0","then":[{"after":-1,"target":"get( \"gate\" ):put( \"r_boom\" , 1)","value":null},{"after":-1,"target":"console","value":"\"The warren has never been so full: \" + rabbits + \" rabbits share the meadow.\""},{"after":-1,"target":"console","value":"\"Young ones tumble through the clover. The elders keep one eye on the tree line.\""}],"if":null},
{"cmd":"rule","name":null,"when":"rabbits < 30 && wolves > 0 && get( \"gate\" ):get( \"r_worry\" , 0) == 0","then":[{"after":-1,"target":"get( \"gate\" ):put( \"r_worry\" , 1)","value":null},{"after":-1,"target":"console","value":"\"A cold wind moves through the warren. Only \" + rabbits + \" remain.\""},{"after":-1,"target":"console","value":"\"The survivors huddle close, listening for howls in the dark.\""}],"if":null},
{"cmd":"rule","name":null,"when":"rabbits < 10 && wolves > 0 && get( \"gate\" ):get( \"r_crisis\" , 0) == 0","then":[{"after":-1,"target":"get( \"gate\" ):put( \"r_crisis\" , 1)","value":null},{"after":-1,"target":"console","value":"\"Catastrophe. Only \" + rabbits + \" rabbits cling to life as the wolves close in.\""}],"if":null},
{"cmd":"rule","name":null,"when":"rabbits == 1 && get( \"gate\" ):get( \"r_one\" , 0) == 0","then":[{"after":-1,"target":"get( \"gate\" ):put( \"r_one\" , 1)","value":null},{"after":-1,"target":"console","value":"\"One. A single rabbit, crouched beneath a thistle, trembling.\""}],"if":null},
{"cmd":"rule","name":null,"when":"rabbits == 0 && wolves > 0 && get( \"gate\" ):get( \"r_gone\" , 0) == 0","then":[{"after":-1,"target":"get( \"gate\" ):put( \"r_gone\" , 1)","value":null},{"after":-1,"target":"console","value":"\"The last rabbit has vanished from the meadow.\""},{"after":-1,"target":"console","value":"\"The wolves pause, muzzles raised, confused by the silence.\""}],"if":null},
{"cmd":"rule","name":null,"when":"wolves > 25 && get( \"gate\" ):get( \"w_rise\" , 0) == 0","then":[{"after":-1,"target":"get( \"gate\" ):put( \"w_rise\" , 1)","value":null},{"after":-1,"target":"console","value":"wolves + \" wolves now prowl the valley.\""},{"after":-1,"target":"console","value":"\"They hunt in relays. There is no safe hour for the rabbits.\""}],"if":null},
{"cmd":"rule","name":null,"when":"wolves > 55 && get( \"gate\" ):get( \"w_peak\" , 0) == 0","then":[{"after":-1,"target":"get( \"gate\" ):put( \"w_peak\" , 1)","value":null},{"after":-1,"target":"console","value":"\"The pack stands at \" + wolves + \". This meadow has never seen so many predators.\""},{"after":-1,"target":"console","value":"\"But with the rabbits thinning fast, the feast cannot last.\""}],"if":null},
{"cmd":"rule","name":null,"when":"wolves < 20 && rabbits == 0 && get( \"gate\" ):get( \"w_hunger\" , 0) == 0","then":[{"after":-1,"target":"get( \"gate\" ):put( \"w_hunger\" , 1)","value":null},{"after":-1,"target":"console","value":"\"Hunger walks with the wolves now. \" + wolves + \" remain — lean, restless, hollow-eyed.\""},{"after":-1,"target":"console","value":"\"There is nothing left to hunt.\""}],"if":null},
{"cmd":"rule","name":null,"when":"wolves < 5 && wolves > 0 && rabbits == 0 && get( \"gate\" ):get( \"w_last\" , 0) == 0","then":[{"after":-1,"target":"get( \"gate\" ):put( \"w_last\" , 1)","value":null},{"after":-1,"target":"console","value":"\"Only \" + wolves + \" wolves remain, ghost-thin, wandering in circles.\""},{"after":-1,"target":"console","value":"\"They have forgotten what it felt like to be full.\""}],"if":null},
{"cmd":"rule","name":null,"when":"wolves == 0 && rabbits == 0","then":[{"after":-1,"target":"console","value":"\"\\n\""},{"after":-1,"target":"console","value":"\"════════════════════════════════════════════════════\""},{"after":-1,"target":"console","value":"\"               S I L E N C E\""},{"after":-1,"target":"console","value":"\"════════════════════════════════════════════════════\""},{"after":-1,"target":"console","value":"\"After \" + get( \"day\" ) + \" days, the meadow is empty.\""},{"after":-1,"target":"console","value":"\"Both species gone — not with fury, but with arithmetic.\""},{"after":-1,"target":"console","value":"\"The grass grows untouched. The wind moves through it anyway.\""},{"after":-1,"target":"console","value":"\"Nature does not mourn. Nature begins again.\""}],"if":null},
