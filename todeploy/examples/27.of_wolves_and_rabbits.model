{"cmd":"script","name":null,"language":"une","onstart":true,"onstop":false,"prestart":false,"prestop":false,"inline":true,"from":["put( \"day\" , 0)\n put( \"gate\" , pair())\n\n console = \"════════════════════════════════════════════════════\" \n console = \"             Of Wolves and Rabbits\" \n console = \"             A Tale Told in Rules\" \n console = \"════════════════════════════════════════════════════\" \n console = \"\\n\" \n console = \"The meadow awakens. Spring is in the air.\" \n console = \"Sixty rabbits graze contentedly in the tall grass,\" \n console = \"unaware that eight wolves watch from the tree line.\" \n console = \"\\n\""],"call":null},
