{"cmd":"rule","name":null,"when":"co2_ppm < 1100 && get( \"gate\" ):get( \"solar_fail\" , 0) == 1 && get( \"gate\" ):get( \"co2_improving\" , 0) == 0","then":[{"after":-1,"target":"get( \"gate\" ):put( \"co2_improving\" , 1)","value":null},{"after":-1,"target":"console","value":"\"[LIFE-SUPPORT] min-\" + sim_time + \": CO₂ descending through \" + co2_ppm:format( \"####\" ) + \" ppm — because scrubbers are responding to the improved power budget, CO₂ removal rate now exceeds crew output.\""}],"if":null},
{"cmd":"rule","name":null,"when":"co2_ppm < 700 && get( \"gate\" ):get( \"solar_fail\" , 0) == 1 && get( \"gate\" ):get( \"co2_nominal\" , 0) == 0","then":[{"after":-1,"target":"get( \"gate\" ):put( \"co2_nominal\" , 1)","value":null},{"after":-1,"target":"console","value":"\"[LIFE-SUPPORT] min-\" + sim_time + \": CO₂ nominal at \" + co2_ppm:format( \"####\" ) + \" ppm. Crew masks removed. Atmospheric composition confirmed within OSHA 18000 limits.\""}],"if":null},
