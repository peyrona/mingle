{"cmd":"rule","name":null,"when":"temperature < 17.0 && get( \"gate\" ):get( \"t_critical\" , 0) == 0","then":[{"after":-1,"target":"get( \"gate\" ):put( \"t_critical\" , 1)","value":null},{"after":-1,"target":"console","value":"\"[THERMAL]      min-\" + sim_time + \": Temperature at \" + temperature:format( \"#0.0\" ) + \"°C — hypothermia risk. Because heating is at minimum, all crew confined to insulated mid-section. Activities suspended.\""}],"if":null},
{"cmd":"rule","name":null,"when":"temperature > 18.5 && get( \"gate\" ):get( \"solar_fail\" , 0) == 1 && get( \"gate\" ):get( \"t_recovering\" , 0) == 0","then":[{"after":-1,"target":"get( \"gate\" ):put( \"t_recovering\" , 1)","value":null},{"after":-1,"target":"console","value":"\"[THERMAL]      min-\" + sim_time + \": Temperature rising through \" + temperature:format( \"#0.0\" ) + \"°C — because heating capacity has been restored alongside power recovery, thermal ascent is confirmed.\""}],"if":null},
{"cmd":"rule","name":null,"when":"temperature > 21.0 && get( \"gate\" ):get( \"solar_fail\" , 0) == 1 && get( \"gate\" ):get( \"t_nominal\" , 0) == 0","then":[{"after":-1,"target":"get( \"gate\" ):put( \"t_nominal\" , 1)","value":null},{"after":-1,"target":"console","value":"\"[THERMAL]      min-\" + sim_time + \": Cabin temperature nominal at \" + temperature:format( \"#0.0\" ) + \"°C. Thermal control systems confirm stable equilibrium.\""}],"if":null},
{"cmd":"rule","name":null,"when":"co2_ppm > 700 && co2_ppm < 1000 && get( \"gate\" ):get( \"co2_elevated\" , 0) == 0","then":[{"after":-1,"target":"get( \"gate\" ):put( \"co2_elevated\" , 1)","value":null},{"after":-1,"target":"console","value":"\"[LIFE-SUPPORT] min-\" + sim_time + \": CO₂ at \" + co2_ppm:format( \"####\" ) + \" ppm — elevated. Because scrubber throughput is limited by power budget, amine cartridge cycling has been increased within available wattage.\""}],"if":null},
{"cmd":"rule","name":null,"when":"co2_ppm > 1000 && get( \"gate\" ):get( \"co2_warning\" , 0) == 0","then":[{"after":-1,"target":"get( \"gate\" ):put( \"co2_warning\" , 1)","value":null},{"after":-1,"target":"console","value":"\"[LIFE-SUPPORT] min-\" + sim_time + \": CO₂ at \" + co2_ppm:format( \"####\" ) + \" ppm — WARNING. Because scrubber fans cannot reach full speed under current power constraints, primary CO₂ removal cannisters are being pre-activated.\""}],"if":null},
