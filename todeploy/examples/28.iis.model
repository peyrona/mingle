{"cmd":"rule","name":null,"when":"solar_output > 95 && power_level > 90 && temperature > 21.0 && co2_ppm < 600 && o2_level > 20.8 && get( \"gate\" ):get( \"solar_fail\" , 0) == 1 && get( \"gate\" ):get( \"all_clear\" , 0) == 0","then":[{"after":-1,"target":"get( \"gate\" ):put( \"all_clear\" , 1)","value":null},{"after":-1,"target":"console","value":"\"\\n\""},{"after":-1,"target":"console","value":"\"════════════════════════════════════════════════════════════════════\""},{"after":-1,"target":"console","value":"\"  [COMMANDER]  min-\" + sim_time + \": INCIDENT RESOLVED.\""},{"after":-1,"target":"console","value":"\"  Because all subsystems have returned to nominal parameters, the\""},{"after":-1,"target":"console","value":"\"  emergency stand-down order is now in effect. Logging to flight\""},{"after":-1,"target":"console","value":"\"  records. Crew commended. Repair EVA team stood down.\""},{"after":-1,"target":"console","value":"\"════════════════════════════════════════════════════════════════════\""},{"after":-1,"target":"console","value":"\"\\n\""},{"after":-1,"target":"voice","value":"\"All systems nominal. Emergency stand-down. Station is go. Well done.\""}],"if":null},
