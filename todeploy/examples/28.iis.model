{"cmd":"rule","name":null,"when":"sim_time && sim_time:mod( 5) == 0 && sim_time > 0","then":[{"after":-1,"target":"console","value":"\"\\n\""},{"after":-1,"target":"console","value":"\"┌─ STATUS REPORT ─ min \" + sim_time + \" ─────────────────────────────────────────────────┐\""},{"after":-1,"target":"console","value":"\"│  Solar: \" + solar_output:format( \"000.0\" ) + \"%   Power: \" + power_level:format( \"00\" ) + \"%   Temp: \" + temperature:format( \"000.0\" ) + \"°C   CO₂: \" + co2_ppm:format( \"0000\" ) + \" ppm   O₂: \" + o2_level:format( \"00.0\" ) + \"%  │\""},{"after":-1,"target":"console","value":"\"└──────────────────────────────────────────────────────────────────────────┘\""},{"after":-1,"target":"console","value":"\"\\n\""}],"if":null},
{"cmd":"rule","name":null,"when":"solar_output < 50 && get( \"gate\" ):get( \"solar_fail\" , 0) == 0","then":[{"after":-1,"target":"get( \"gate\" ):put( \"solar_fail\" , 1)","value":null},{"after":-1,"target":"console","value":"\"[SOLAR]        min-\" + sim_time + \": Micrometeorite confirmed on array B — output fell to \" + solar_output + \"%. Because battery is now the primary source, power drain begins.\""},{"after":-1,"target":"voice","value":"\"Alert. Solar array failure detected. Power generation at \" + solar_output + \" percent. Switching to battery reserves.\""}],"if":null},
{"cmd":"rule","name":null,"when":"solar_output > 60 && solar_output < 90 && get( \"gate\" ):get( \"solar_partial\" , 0) == 0","then":[{"after":-1,"target":"get( \"gate\" ):put( \"solar_partial\" , 1)","value":null},{"after":-1,"target":"console","value":"\"[SOLAR]        min-\" + sim_time + \": Repair crew has replaced junction B-7 — solar output climbed to \" + solar_output + \"%. Because power generation now exceeds minimum threshold, battery drain is reduced.\""},{"after":-1,"target":"voice","value":"\"Repair crew reports partial success. Solar output at \" + solar_output + \" percent. Power stabilising.\""}],"if":null},
{"cmd":"rule","name":null,"when":"solar_output > 95 && get( \"gate\" ):get( \"solar_fail\" , 0) == 1 && get( \"gate\" ):get( \"solar_full\" , 0) == 0","then":[{"after":-1,"target":"get( \"gate\" ):put( \"solar_full\" , 1)","value":null},{"after":-1,"target":"console","value":"\"[SOLAR]        min-\" + sim_time + \": Full solar array nominal at \" + solar_output + \"%. Because generation now exceeds demand, charging of battery reserves has begun.\""}],"if":null},
{"cmd":"rule","name":null,"when":"power_level < 90 && power_level > 70 && get( \"gate\" ):get( \"p_watch\" , 0) == 0","then":[{"after":-1,"target":"get( \"gate\" ):put( \"p_watch\" , 1)","value":null},{"after":-1,"target":"console","value":"\"[POWER MGMT]   min-\" + sim_time + \": Battery at \" + power_level:format( \"##\" ) + \"% — because solar input is at \" + solar_output + \"%, reserves are being consumed. Monitoring trajectory.\""}],"if":null},
{"cmd":"rule","name":null,"when":"power_level < 70 && get( \"gate\" ):get( \"p_shedding\" , 0) == 0","then":[{"after":-1,"target":"get( \"gate\" ):put( \"p_shedding\" , 1)","value":null},{"after":-1,"target":"console","value":"\"[POWER MGMT]   min-\" + sim_time + \": Battery at \" + power_level:format( \"##\" ) + \"% — because solar deficit is sustained, initiating load shedding AMBER. Science module, gym, and entertainment systems offline.\""},{"after":-1,"target":"voice","value":"\"Power conservation mode activated. Non-essential systems offline.\""}],"if":null},
{"cmd":"rule","name":null,"when":"power_level < 52 && get( \"gate\" ):get( \"p_critical\" , 0) == 0","then":[{"after":-1,"target":"get( \"gate\" ):put( \"p_critical\" , 1)","value":null},{"after":-1,"target":"console","value":"\"[POWER MGMT]   min-\" + sim_time + \": Battery at \" + power_level:format( \"##\" ) + \"% — CRITICAL threshold crossed. Because heating and CO₂ scrubbers are drawing more than available, both are now throttled.\""},{"after":-1,"target":"voice","value":"\"Battery critical. Emergency power conservation active. Life support systems throttled.\""}],"if":null},
{"cmd":"rule","name":null,"when":"power_level < 43 && get( \"gate\" ):get( \"p_emergency\" , 0) == 0","then":[{"after":-1,"target":"get( \"gate\" ):put( \"p_emergency\" , 1)","value":null},{"after":-1,"target":"console","value":"\"[POWER MGMT]   min-\" + sim_time + \": Battery at \" + power_level:format( \"##\" ) + \"% — EMERGENCY floor reached. Because further drain risks irreversible cell damage, all non-life-critical loads suspended.\""}],"if":null},
{"cmd":"rule","name":null,"when":"power_level > 60 && get( \"gate\" ):get( \"solar_fail\" , 0) == 1 && get( \"gate\" ):get( \"p_recovering\" , 0) == 0","then":[{"after":-1,"target":"get( \"gate\" ):put( \"p_recovering\" , 1)","value":null},{"after":-1,"target":"console","value":"\"[POWER MGMT]   min-\" + sim_time + \": Battery climbing through \" + power_level:format( \"##\" ) + \"%. Because solar input now exceeds demand, throttled systems are being progressively restored.\""}],"if":null},
{"cmd":"rule","name":null,"when":"power_level > 85 && get( \"gate\" ):get( \"solar_fail\" , 0) == 1 && get( \"gate\" ):get( \"p_nominal\" , 0) == 0","then":[{"after":-1,"target":"get( \"gate\" ):put( \"p_nominal\" , 1)","value":null},{"after":-1,"target":"console","value":"\"[POWER MGMT]   min-\" + sim_time + \": Battery at \" + power_level:format( \"##\" ) + \"% — within nominal range. Load shedding protocol AMBER has been lifted.\""}],"if":null},
{"cmd":"rule","name":null,"when":"temperature < 21.0 && temperature > 19.0 && get( \"gate\" ):get( \"t_cooling\" , 0) == 0","then":[{"after":-1,"target":"get( \"gate\" ):put( \"t_cooling\" , 1)","value":null},{"after":-1,"target":"console","value":"\"[THERMAL]      min-\" + sim_time + \": Cabin temperature at \" + temperature:format( \"#0.0\" ) + \"°C — because available heating power dropped with battery level, a slow thermal descent has begun.\""}],"if":null},
