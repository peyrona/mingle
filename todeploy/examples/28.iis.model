{"cmd":"script","name":null,"language":"une","onstart":true,"onstop":false,"prestart":false,"prestop":false,"inline":true,"from":["put( \"gate\" , pair())\n\n console = \"════════════════════════════════════════════════════════════════════\" \n console = \"  IIS — Intelligent Isolated Station  ·  Mission Simulation v1.0\" \n console = \"════════════════════════════════════════════════════════════════════\" \n console = \"  ORBITAL ALTITUDE  :  417 km\" \n console = \"  CREW              :  6 personnel\" \n console = \"  SIMULATION RATE   :  1 simulated minute per 3 seconds\" \n console = \"════════════════════════════════════════════════════════════════════\" \n console = \"\\n\" \n voice = \"Station IIS online. All systems nominal. Beginning mission simulation.\""],"call":null},
