#     DRIVER ShellyRGBWPMDriver
#         CONFIG
#             ip      SET _SHELLY_IP_
#             channel SET 0
#             type    SET "white"

# DEVICE white_B
#     DRIVER ShellyRGBWPMDriver
#         CONFIG
#             ip      SET _SHELLY_IP_
#             channel SET 1
#             mode    SET "white"

# DEVICE white_C
#     DRIVER ShellyRGBWPMDriver
#         CONFIG
#             ip      SET _SHELLY_IP_
#             channel SET 2
#             mode    SET "white"

