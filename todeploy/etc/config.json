# ----------------------------------------------------------------------------------------------------------------------------------
# Initial note: Mingle Standard Platform (MSP) allows Une-style comments in JSON files.
#
# This file contains all the configuration needed by the MSP tools.
# All values here can be also passed at command line using same names (keys).
# All values can be set as OS Environment Variables using same names (keys).
# Precedence order is:
#   1. CLI vars
#   2. OS vars
#   3. Config file
#
# The same conf file can be used to configure more than one tool (Stick, Gum, ...) but only one instace of every tool.
#
# For more information, please refer to the MSP handbook.
# ----------------------------------------------------------------------------------------------------------------------------------

[
    # Common configuration to all Mingle modules
    {
      "module"           : "common",
      "log_level"        : "warning",   # Valid:
      "log_expire"       : 30           # Log files older than this amount of days will be automatically deleted (x <=0 to not delete
    },

    # Excution Environment configuration
    {
      "module"                 : "exen",
      "bus_capacity"           : 4096,     # Max amount of messages that can be stored peding to be dispatched. By default 16000. Bus starts small and grows up to this amount: an exception is the thrown.
      "write_disk"             : true,     # Is it allowed to use disk (read and write)? By default, true, (unless HD is not writable).
      "faked_drivers"          : false,    # A hint for the drivers. By default: false.
      "downtimed_interval"     : 180,      # Seconds between invocations to find downtimed devices (0 to disable). By default 0.
      "downtimed_report_device": null,     # The name of the device that will contain the list of downtimed devices
      "model"                  : null,     # Local or remote (http/s) file (or array of files: first valid will be used) to be executed. By default null.
      "update_models"          : true,     # Update local model if a more recent one was retrieved from HTTP. By default, true.
      "allow_native_code"      : true,     # Allow executing code in other languages, besides Une (drivers are an exception). By default true.
      "languages"              : [ {"name": "Une"       , "class": "com.peyrona.mingle.candi.unescript.UneScriptRT", "uris": ["file://{*home.lib*}candi.jar"] },
                                   {"name": "Java"      , "class": "com.peyrona.mingle.candi.javac.JavaRT"         , "uris": ["file://{*home.lib*}candi.jar"] },
                                   {"name": "JavaScript", "class": "com.peyrona.mingle.candi.graalvm.GraalJsRT",
                                    "uris": ["file://{*home.lib*}candi.jar",
                                             "file://{*home.lib*}graal-sdk-23.0.11.jar",
                                             "file://{*home.lib*}truffle-api-23.0.11.jar",
                                             "file://{*home.lib*}js-23.0.11.jar",
                                             "file://{*home.lib*}regex-23.0.11.jar",
                                             "file://{*home.lib*}icu4j-72.1.jar"],
                                    "download": [{"local" : "file://{*home.lib*}icu4j-72.1.jar",
                                                  "remote": "https://repo1.maven.org/maven2/com/ibm/icu/icu4j/72.1/icu4j-72.1.jar"}] },
                                   {"name": "Python"    , "class": "com.peyrona.mingle.candi.graalvm.GraalPyRT",
                                    "uris": ["file://{*home.lib*}candi.jar",
                                             "file://{*home.lib*}graal-sdk-23.0.11.jar",
                                             "file://{*home.lib*}truffle-api-23.0.11.jar",
                                             "file://{*home.lib*}graalpython-23.0.11.jar"],
                                    "download": [{"local" : "file://{*home.lib*}graalpython-23.0.11.jar",
                                                  "remote": "https://repo1.maven.org/maven2/org/graalvm/tools/graalpython/23.0.11/graalpython-23.0.11.jar"}] },
                                   {"name": "Ruby"      , "class": "com.peyrona.mingle.candi.graalvm.GraalRubyRT",
                                    "uris": ["file://{*home.lib*}candi.jar",
                                             "file://{*home.lib*}graal-sdk-23.0.11.jar",
                                             "file://{*home.lib*}truffle-api-23.0.11.jar",
                                             "file://{*home.lib*}ruby-23.0.11.jar"],
                                    "download": [{"local" : "file://{*home.lib*}ruby-23.0.11.jar",
                                                  "remote": "https://repo1.maven.org/maven2/org/graalvm/ruby/ruby/23.0.11/ruby-23.0.11.jar"}] },
                                   {"name": "R"         , "class": "com.peyrona.mingle.candi.graalvm.GraalRRT",
                                    "uris": ["file://{*home.lib*}candi.jar",
                                             "file://{*home.lib*}graal-sdk-23.0.11.jar",
                                             "file://{*home.lib*}truffle-api-23.0.11.jar",
                                             "file://{*home.lib*}r-23.0.11.jar"],
                                    "download": [{"local" : "file://{*home.lib*}r-23.0.11.jar",
                                                  "remote": "https://repo1.maven.org/maven2/org/graalvm/r/r/23.0.11/r-23.0.11.jar"}] },
                                   # Native shared libraries (.so / .dll / .dylib) via JNA.
                                   # "C", "Rust", and "Native" are aliases for the same runtime.
                                   # jna-5.14.0.jar (~1.5 MB) is downloaded automatically on first use.
                                   {"name": "C"         , "class": "com.peyrona.mingle.candi.jna.NativeRT",
                                    "uris": ["file://{*home.lib*}candi.jar",
                                             "file://{*home.lib*}jna-5.14.0.jar"],
                                    "download": [{"local" : "file://{*home.lib*}jna-5.14.0.jar",
                                                  "remote": "https://repo1.maven.org/maven2/net/java/dev/jna/jna/5.14.0/jna-5.14.0.jar"}] },
                                   {"name": "Rust"      , "class": "com.peyrona.mingle.candi.jna.NativeRT",
                                    "uris": ["file://{*home.lib*}candi.jar",
                                             "file://{*home.lib*}jna-5.14.0.jar"] },
                                   {"name": "Native"    , "class": "com.peyrona.mingle.candi.jna.NativeRT",
                                    "uris": ["file://{*home.lib*}candi.jar",
                                             "file://{*home.lib*}jna-5.14.0.jar"] } ]
    },

    # Monitoring (HTTP Server and ExEn Bridge) module.
    # See The_Mingle_Standard_Platform.pdf for more info.
    {
      "module"         : "monitoring",
      "host"           : null,                   # Host name (by default 'localhost')
      "port"           : null,                   # Port to attend HTTP (by default 8080)
      "timeout"        : 1800,                   # Session timeout in seconds (by default 1800 == 30 mins), Use 0 to last forever
      "allow"          : "intranet",             # "allow": "local", "subnet" (192.168.7.*), "intranet" (192.168.*.*), "any". Default is "intranet"
      "user_base"      : null,                   # Folder for Dashboards and static content (served via HTTP/S). By default "{*home*}/etc/gum_user_base"
      "shared_secret"  : null,                   # HMAC shared secret for API authentication. If null, authentication is disabled.
      "hmac_tolerance" : 60,                     # Accept timestamps within ±N seconds. Default: 60
      "master_password": null,                   # To access dahsboards as admin (new, del, etc) and to access file manger. To allow all users: null
      "proxies"        : []                      # Reverse-proxy routes. Each entry: { "path": "/gum/proxy/rpi", "target": "http://192.168.7.9:8080" }
                                                 # "path"   - context path on this server (must be unique and start with /gum/proxy/)
                                                 # "target" - base URL of the downstream server to forward requests to
     #"ssl": { "port": null,                     # Port to attend HTTPS (by default 8443). When "ssl" is null, HTTPS will not be attended
     #         "path": "{*home*}keystore.jks",   # Path to "keystore.jks" file (can not be null)
     #         "pwd" : "adminadmin" },           # Password for the "keystore.jks" file (can not be null)
    },

    # Plugable Arithmetic and Logical Expression Evaluator to be used (loaded at run-time)
    {
      "module": "expreval",
      "class" : "com.peyrona.mingle.lang.xpreval.NAXE",
      "uris"  : ["file://{*home.lib*}lang.jar"]
    },

    # Plugable Commmands Incarnation Library to be used (loaded at run-time)
    {
      "module": "cil",
      "class" : "com.peyrona.mingle.cil.CilBuilder",
      "uris"  : ["file://{*home.lib*}cil.jar"]
    },

    # Grid: to receive and send messages (changes and requests).
    # Used by:
    #    * ExEns (Stick) to broadcast messages to other ExEns in the same grid.
    #    * Gum (monitoring) to find the network protocol that an ExEn accepts.
    #
    # The "network" key here contains which one to use (among those under module "network").
    # To fine-tune, use an object e.g.: { "name": "Plain Socket Server", "port": 4444 }.
    # One or more "localhost" can be used: the Stick will create one server per each one.
    {
        "module": "grid",
        "nodes" : [
                    { "host": "localhost", "network": "Plain Socket Server" }
                  # { "host": "localhost"          , "network": { "name": "Plain Socket Server", "init": { "port": 44444 } } },
                  # { "host": "192.168.1.111:65533", "network": { "name": "Plain Socket Client", "timeout": 90 } }
                  ]
    },

    # Nework module is in charge of accepting remote connections and/or Grid Nodes to connect to (useed by Stick and Glue).
    # Sockets, queues and transactions (among others) can be used.
    # The "init" object allows any kind of configuration: it is passed as string to the "builder".
    {
        "module": "network",

        # Servers: transport channels to receive requests sent by other ExEns and tools (e.g. Glue)

        "servers": [
                      {
                        "name"       : "Plain Socket Server",                                  # "name" is mandatory
                        "description": "TCP socket connection without encryption",             # Optional but recommened
                        "init"       : { "port"  : 55880,                                      # By default, 55880 for plain sockets and 55881 for SSL
                                         "allow" : "intranet" },                               # "allow": "local", "subnet" (192.168.7.*), "intranet" (192.168.*.*), "any". Default is "intranet"
                        "builder"    : "com.peyrona.mingle.network.socket.SocketServer",       # How to create the server that accept connections
                        "uris"       : ["file://{*home.lib*}network.jar"]
                      },
                    # {
                    #   "name"       : "SSL Socket Server",                                    # "name" is mandatory
                    #   "description": "TCP socket connection with TLS encryption",            # Optional but recommened
                    #   "init"       : { "port"    : 55881,                                    # By default, 55881 for plain sockets and 55881 for SSL
                    #                    "certFile": "./certificate.p12",                      # SSL Certificate file
                    #                    "keyFile" : "./private.key",                          # Private Key File
                    #                    "password": "mypass",                                 # Certificate password
                    #                    "allow"   : "any" },                                  # "allow": "local", "subnet" (192.168.7.*), "intranet" (192.168.*.*), "any". Default is "intranet"
                    #   "builder"    : "com.peyrona.mingle.network.socket.SocketServer",       # How to create the server that accepts the connections
                    #   "uris"       : ["file://{*home.lib*}network.jar"]
                    # },
                      {
                        "name"       : "Plain WebSocket Server",                               # "name" is mandatory
                        "description": "WebSocket connection without encryption",              # Optional but recommened
                        "init"       : { "port"  : 55882,                                      # By default, 55882 for plain sockets and 55881 for SSL
                                         "allow" : "intranet",                                 # "allow": "local", "subnet" (192.168.7.*), "intranet" (192.168.*.*), "any". Default is "intranet"
                                         "ssl"   : false },                                    # Use SSL or not. By default false.
                        "builder"    : "com.peyrona.mingle.network.websocket.WebSocketServer", # How to create the server that accept connections
                        "uris"       : ["file://{*home.lib*}network.jar",
                                        "file://{*home.lib*}gum/*.jar"]
                      }
                    # ,
                    # {
                    #   "name"       : "SSL WebSocket Server",                                 # "name" is mandatory
                    #   "description": "TCP socket connection with TLS encryption",            # Optional but recommened
                    #   "init"       : { "port"    : 55883,                                    # By default, 55883 for plain sockets and 55881 for SSL
                    #                    "certFile": "./certificate.p12",                      # SSL Certificate file
                    #                    "keyFile" : "./private.key",                          # Private Key File
                    #                    "password": "mypass",                                 # Certificate password
                    #                    "allow"   : "any" },                                  # "allow": "local", "subnet" (192.168.7.*), "intranet" (192.168.*.*), "any". Default is "intranet"
                    #   "builder"    : "com.peyrona.mingle.network.websocket.WebSocketServer", # How to create the server that accept connections
                    #   "uris"       : ["file://{*home.lib*}network.jar",
                    #                   "file://{*home.lib*}gum/*.jar"]
                    # }
                   ],

        # Transport channels to create clients that will send requests to servers (mainly used by Gum).
        # Note: the Server IP is provided at run-time.

        "clients": [
                      {
                        "name"       : "Plain Socket Client",                                  # "name" is mandatory
                        "description": "TCP socket connection without encryption",             # Optional but recommened
                        "init"       : { "host"    : null,                                     # By default 'localhost'
                                         "port"    : 55880,                                    # By default, 55880 for plain sockets and 55881 for websockets
                                         "timeout" : 30 },                                     # Seconds to wait to stablish the connection. By default 0 (wait forever)
                        "builder"    : "com.peyrona.mingle.network.socket.SocketClient",       # How to create the client
                        "uris"       : ["file://{*home.lib*}network.jar"],
                        "ui"         :
                                       [
                                          {
                                            "key": "host",
                                            "type": "string",
                                            "label": "Host",
                                            "tooltip": "",
                                            "default": "localhost",
                                            "required": true,
                                            "validation": {"pattern": "^[a-zA-Z0-9.-]+$"}
                                          },
                                          {
                                            "key": "port",
                                            "type": "integer",
                                            "label": "Port",
                                            "tooltip": "",
                                            "default": 55880,
                                            "required": true,
                                            "validation": {"min": 1024, "max": 65535}
                                          },
                                          {
                                            "key": "timeout",
                                            "type": "integer",
                                            "label": "Timeout (seconds)",
                                            "tooltip": "",
                                            "default": 30,
                                            "required": false,
                                            "validation": {"min": 1, "max": 300}
                                          }
                                      ]
                      },
                      {
                        "name"       : "SSL Socket Client",                                  # "name" is mandatory
                        "description": "TCP socket connection with TLS encryption",          # Optional but recommened
                        "init"       : { "host"    : null,                                   # By default 'localhost'
                                         "port"    : 55881,                                  # By default, 55880 for plain sockets and 55881 for SSL
                                         "timeout" : 30 },                                   # Seconds to wait to stablish the connection. By default 0 (wait forever)
                        "builder"    : "com.peyrona.mingle.network.socket.SSLSocketClient",  # How to create the client
                        "uris"       : ["file://{*home.lib*}network.jar"],
                        "ui"         :
                                       [
                                          {
                                            "key": "host",
                                            "type": "string",
                                            "label": "Host",
                                            "tooltip": "",
                                            "default": "localhost",
                                            "required": true,
                                            "validation": {"pattern": "^[a-zA-Z0-9.-]+$"}
                                          },
                                          {
                                            "key": "port",
                                            "type": "integer",
                                            "label": "Port",
                                            "tooltip": "",
                                            "default": 55881,
                                            "required": true,
                                            "validation": {"min": 1024, "max": 65535}
                                          },
                                          {
                                            "key": "timeout",
                                            "type": "integer",
                                            "label": "Timeout (seconds)",
                                            "tooltip": "",
                                            "default": 30,
                                            "required": false,
                                            "validation": {"min": 1, "max": 300}
                                          },
                                          {
                                            "key": "cert_file",
                                            "type": "file",
                                            "label": "Certificate File",
                                            "tooltip": "",
                                            "required": true,
                                            "accept": [".pem", ".crt", ".cer"]
                                          },
                                          {
                                            "key": "key_file",
                                            "type": "file",
                                            "label": "Key File",
                                            "tooltip": "",
                                            "required": true,
                                            "accept": [".key", ".pem"]
                                          },
                                          {
                                            "key": "password",
                                            "type": "password",
                                            "label": "Certificate Password",
                                            "tooltip": "",
                                            "required": false
                                          }
                                      ]
                      },
                      {
                        "name"       : "WebSocket Client",
                        "description": "WebSocket connection for real-time web communication",
                        "init"       : { "host"    : null,
                                         "port"    : 55882,
                                         "ssl"     : false,
                                         "timeout" : 30 },
                        "builder"    : "com.peyrona.mingle.network.websocket.WebSocketClient",
                        "uris"       : ["file://{*home.lib*}network.jar", "file://{*home.lib*}gum/*.jar"],
                        "ui"         :
                                       [
                                          {
                                            "key": "host",
                                            "type": "string",
                                            "label": "Host",
                                            "tooltip": "",
                                            "default": "localhost",
                                            "required": true,
                                            "validation": {"pattern": "^[a-zA-Z0-9.-]+$"}
                                          },
                                          {
                                            "key": "port",
                                            "type": "integer",
                                            "label": "Port",
                                            "tooltip": "",
                                            "default": 55882,
                                            "required": true,
                                            "validation": {"min": 1024, "max": 65535}
                                          },
                                          {
                                            "key": "timeout",
                                            "type": "integer",
                                            "label": "Timeout (seconds)",
                                            "tooltip": "",
                                            "default": 30,
                                            "required": false,
                                            "validation": {"min": 1, "max": 300}
                                          }
                                        ]
                        }

                  ]
    }
]
